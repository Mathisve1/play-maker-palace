[
  {
    "id": "TC001",
    "title": "Volunteer signup shows validation errors for invalid email and mismatched passwords",
    "description": "Verifies signup form blocks submission and shows clear validation messages for invalid email format and password mismatch.",
    "category": "Authentication & Legal Onboarding",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /signup"
      },
      {
        "type": "action",
        "description": "Type \"invalid-email-format\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"ValidPass123!\" into the password field"
      },
      {
        "type": "action",
        "description": "Type \"DifferentPass123!\" into the confirm password field"
      },
      {
        "type": "action",
        "description": "Click the register button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"email\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"password\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/signup\""
      }
    ]
  },
